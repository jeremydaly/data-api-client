generator client {
  provider = "prisma-client-js"
  output   = "./generated-mysql"
}

datasource db {
  provider = "mysql"
}

model PrismaUser {
  id     Int     @id @default(autoincrement())
  email  String  @unique
  name   String?
  age    Int?
  active Boolean @default(true)
  posts  PrismaPost[]

  @@map("prisma_it_user")
}

model PrismaPost {
  id       Int    @id @default(autoincrement())
  title    String
  authorId Int
  author   PrismaUser @relation(fields: [authorId], references: [id])

  @@map("prisma_it_post")
}
